# Environment variables for Website Scraper MCP Server
# Copy this file to .env and fill in your values.

# ── Playwright ──────────────────────────────────────────────────────────────────
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_HEADLESS=true

# ── Crawler ─────────────────────────────────────────────────────────────────────
MAX_CRAWL_DEPTH=2
MAX_PAGES_PER_SITE=100
CRAWL_DELAY_SECONDS=0.5

# ── Chunking ────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Server ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MCP_SERVER_NAME=website-scraper-mcp
MCP_SERVER_VERSION=1.0.0
